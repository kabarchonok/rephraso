    "stylelint-config-html": "1.1.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.0"
